{
  "name": "app-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node server/scripts/start.mjs",
    "seed": "tsx server/scripts/seed.ts",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "vitest --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts --watch",
    "test:coverage": "vitest --config tests/vitest.config.ts --coverage --run",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.96.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@prisma/client": "^5.18.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^1.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^23.0.1",
    "prisma": "^5.18.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.0.2"
  }
}
